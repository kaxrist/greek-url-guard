#: includes/class-admin.php:335
msgid "Article title in Greek"
msgstr "Τίτλος άρθρου στα ελληνικά"

#: includes/class-health-check.php:358
msgid "at least %d matches"
msgstr "τουλάχιστον %d αντιστοιχίες"

#: greek-url-guard.php:5
msgid "Convert new Greek slugs and upload filenames into clean, SEO-friendly Greeklish without changing existing URLs."
msgstr "Μετατρέπει νέα ελληνικά slugs και ονόματα αρχείων μεταφόρτωσης σε καθαρά, SEO-friendly Greeklish, χωρίς να αλλάζει υπάρχοντα URLs."

#: includes/class-admin.php:271
msgid "Categories, tags, and taxonomies"
msgstr "Κατηγορίες, ετικέτες και ταξινομήσεις"

#: greek-url-guard.php:9
msgid "CCDesign.gr"
msgstr "CCDesign.gr"

#: includes/class-admin.php:321
msgid "Content slugs are never reverted or deleted on uninstall."
msgstr "Τα slugs περιεχομένου δεν επαναφέρονται ούτε διαγράφονται ποτέ κατά την απεγκατάσταση."

#: includes/class-admin.php:236
msgid "Core Settings"
msgstr "Βασικές ρυθμίσεις"

#: includes/class-admin.php:250
msgid "Coverage"
msgstr "Κάλυψη"

#: includes/class-admin.php:234
msgid "Create clean Greeklish slugs and upload filenames for new WordPress content without rewriting existing URLs."
msgstr "Δημιουργεί καθαρά Greeklish slugs και ονόματα αρχείων για νέο περιεχόμενο WordPress, χωρίς να αλλάζει υπάρχοντα URLs."

#: includes/class-admin.php:267
msgid "Custom post types"
msgstr "Προσαρμοσμένοι τύποι περιεχομένου"

#: includes/class-health-check.php:403 includes/class-health-check.php:414
msgid "Custom slug code"
msgstr "Custom κώδικας για slugs"

#: includes/class-admin.php:291
msgid "Default: 70 characters. The limit is applied without cutting words when possible."
msgstr "Προεπιλογή: 70 χαρακτήρες. Το όριο εφαρμόζεται χωρίς να κόβει λέξεις όπου είναι δυνατό."

#: includes/class-health-check.php:758
msgid "Detected: %s. Greek URL Guard only works on slugs and new upload filenames; it does not edit builder content or translated strings."
msgstr "Ανιχνεύθηκε: %s. Το Greek URL Guard λειτουργεί μόνο σε slugs και νέα ονόματα αρχείων μεταφόρτωσης. Δεν επεξεργάζεται περιεχόμενο builder ή μεταφρασμένα κείμενα."

#: includes/class-admin.php:245
msgid "Enable automatic cleanup"
msgstr "Ενεργοποίηση αυτόματου καθαρισμού"

#: includes/class-admin.php:292 includes/class-admin.php:302
msgid "Example:"
msgstr "Παράδειγμα:"

#: includes/class-health-check.php:255
msgid "Existing categories, tags, or other public taxonomy items with Greek slugs were found (%1$s). Examples: %2$s. New items are cleaned automatically; old URLs are left unchanged."
msgstr "Βρέθηκαν υπάρχουσες κατηγορίες, ετικέτες ή άλλα δημόσια στοιχεία ταξινόμησης με ελληνικά slugs (%1$s). Παραδείγματα: %2$s. Τα νέα στοιχεία καθαρίζονται αυτόματα. Τα παλιά URLs μένουν αμετάβλητα."

#: includes/class-health-check.php:251 includes/class-health-check.php:263
msgid "Existing category/tag slugs"
msgstr "Υπάρχοντα slugs κατηγοριών/ετικετών"

#: includes/class-health-check.php:219
msgid "Existing Greek post or page slugs were found (%1$s). Examples: %2$s. Greek URL Guard does not rewrite old URLs automatically. Review them before changing anything, because redirects may be needed."
msgstr "Βρέθηκαν υπάρχοντα ελληνικά slugs σε άρθρα ή σελίδες (%1$s). Παραδείγματα: %2$s. Το Greek URL Guard δεν αλλάζει αυτόματα παλιά URLs. Ελέγξτε τα πριν κάνετε αλλαγές, γιατί μπορεί να χρειαστούν redirects."

#: includes/class-health-check.php:289
msgid "Existing media files with Greek characters in the filename were found (%1$s). Examples: %2$s. New uploads are cleaned automatically; old files are not renamed."
msgstr "Βρέθηκαν υπάρχοντα αρχεία media με ελληνικούς χαρακτήρες στο όνομα αρχείου (%1$s). Παραδείγματα: %2$s. Τα νέα uploads καθαρίζονται αυτόματα. Τα παλιά αρχεία δεν μετονομάζονται."

#: includes/class-health-check.php:215 includes/class-health-check.php:227
msgid "Existing post/page slugs"
msgstr "Υπάρχοντα slugs άρθρων/σελίδων"

#: includes/class-admin.php:377
msgid "Good"
msgstr "Καλό"

#: includes/class-admin.php:96 includes/class-admin.php:97 includes/class-admin.php:228 greek-url-guard.php:3
msgid "Greek URL Guard"
msgstr "Greek URL Guard"

#: includes/class-admin.php:379
msgid "Info"
msgstr "Πληροφορία"

#: includes/class-health-check.php:747 includes/class-health-check.php:754
msgid "Integrations"
msgstr "Ενσωματώσεις"

#: includes/class-admin.php:306
msgid "Manual slugs"
msgstr "Χειροκίνητα slugs"

#: includes/class-health-check.php:337
msgid "matching records found"
msgstr "βρέθηκαν σχετικές εγγραφές"

#: includes/class-admin.php:297
msgid "Maximum filename basename length"
msgstr "Μέγιστο μήκος ονόματος αρχείου"

#: includes/class-admin.php:287
msgid "Maximum slug length"
msgstr "Μέγιστο μήκος slug"

#: includes/class-admin.php:275
msgid "Media file names"
msgstr "Ονόματα αρχείων media"

#: includes/class-health-check.php:285 includes/class-health-check.php:297
msgid "Media filenames"
msgstr "Ονόματα αρχείων media"

#: includes/class-admin.php:380
msgid "Neutral"
msgstr "Ουδέτερο"

#: includes/class-health-check.php:416
msgid "No active snippet, theme file, custom file, or runtime hook that looks like a Greek slug or filename converter was detected."
msgstr "Δεν εντοπίστηκε ενεργό snippet, αρχείο theme, custom αρχείο ή runtime hook που να μοιάζει με μετατροπέα ελληνικών slugs ή ονομάτων αρχείων."

#: includes/class-health-check.php:265
msgid "No Greek category, tag, or taxonomy slugs were detected in a lightweight check."
msgstr "Δεν εντοπίστηκαν ελληνικά slugs σε κατηγορίες, ετικέτες ή ταξινομήσεις στον γρήγορο έλεγχο."

#: includes/class-health-check.php:299
msgid "No Greek media filenames were detected in a lightweight check."
msgstr "Δεν εντοπίστηκαν ελληνικά ονόματα αρχείων media στον γρήγορο έλεγχο."

#: includes/class-health-check.php:229
msgid "No Greek post or page slugs were detected in a lightweight check."
msgstr "Δεν εντοπίστηκαν ελληνικά slugs σε άρθρα ή σελίδες στον γρήγορο έλεγχο."

#: includes/class-health-check.php:749
msgid "No WooCommerce, page builder, or translation plugin was detected. No action is needed."
msgstr "Δεν ανιχνεύθηκε WooCommerce, page builder ή plugin μετάφρασης. Δεν χρειάζεται ενέργεια."

#: includes/class-admin.php:282
msgid "Old URLs and existing uploaded files are not changed."
msgstr "Παλιά URLs και υπάρχοντα αρχεία δεν αλλάζουν."

#: includes/class-admin.php:263
msgid "Pages"
msgstr "Σελίδες"

#: includes/class-health-check.php:53 includes/class-health-check.php:60
msgid "Permalinks"
msgstr "Μόνιμοι σύνδεσμοι"

#: includes/class-admin.php:259
msgid "Posts"
msgstr "Άρθρα"

#: includes/class-admin.php:255
msgid "Posts and pages"
msgstr "Άρθρα και σελίδες"

#: includes/class-health-check.php:407
msgid "Potential active custom code that may alter Greek slugs or filenames was detected: %s. Review it before enabling Greek URL Guard automations."
msgstr "Εντοπίστηκε πιθανός ενεργός custom κώδικας που μπορεί να αλλάζει ελληνικά slugs ή ονόματα αρχείων: %s. Ελέγξτε τον πριν ενεργοποιήσετε τους αυτοματισμούς του Greek URL Guard."

#: includes/class-admin.php:310
msgid "Preserve manually entered slugs"
msgstr "Διατήρηση χειροκίνητων slugs"

#: includes/class-admin.php:312
msgid "Changing the title of published content does not rewrite its existing URL. This option only controls slugs typed directly in the slug field."
msgstr "Η αλλαγή τίτλου σε δημοσιευμένο περιεχόμενο δεν ξαναγράφει το υπάρχον URL. Αυτή η ρύθμιση αφορά μόνο slugs που πληκτρολογούνται απευθείας στο πεδίο slug."

#: includes/class-health-check.php:55
msgid "Pretty permalinks are disabled. Slug quality matters most when pretty permalinks are enabled."
msgstr "Οι καθαροί μόνιμοι σύνδεσμοι είναι απενεργοποιημένοι. Η ποιότητα των slugs έχει μεγαλύτερη σημασία όταν είναι ενεργοί."

#: includes/class-health-check.php:62
msgid "Pretty permalinks are enabled."
msgstr "Οι καθαροί μόνιμοι σύνδεσμοι είναι ενεργοί."

